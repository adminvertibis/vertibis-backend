# Option 1: full connection string (Railway / Neon / Render)
DATABASE_URL=postgresql://user:password@host:5432/vertibis

# Option 2: individual vars (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vertibis
DB_USER=postgres
DB_PASSWORD=postgres

# Directory to store uploaded files locally
UPLOAD_DIR=uploads

# Optional: Anthropic API key for LLM advisories
ANTHROPIC_API_KEY=

# Optional: outbound email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@vertibis.in
ADMIN_EMAIL=admin@vertibis.in
FRONTEND_LOGIN_URL=https://your-frontend-domain/login
